flowchart LR
    Admin((Administrator))
    Staff((Staff))

    subgraph System["Train Schedule & Reservation Management System"]
        UC1[Login]
        UC2[Logout]
        UC3[Manage Trains]
        UC3a[Add Train]
        UC3b[Update Train]
        UC3c[Delete Train]
        UC4[Manage Passengers]
        UC4a[Add Passenger]
        UC4b[Update Passenger]
        UC4c[Delete Passenger]
        UC5[Manage Reservations]
        UC5a[Book Ticket]
        UC5b[Cancel Ticket]
        UC5c[View Confirmation]
        UC6[View Dashboard]
        UC7[Generate Reports]
        UC7a[Booking Report]
        UC7b[Revenue Report]
        UC7c[Utilization Report]
        UC7d[Passenger Report]
    end

    Admin --- UC1
    Admin --- UC2
    Admin --- UC3
    Admin --- UC4
    Admin --- UC5
    Admin --- UC6
    Admin --- UC7

    Staff --- UC1
